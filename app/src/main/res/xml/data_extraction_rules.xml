<?xml version="1.0" encoding="utf-8"?>
<!--
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
-->
<data-extraction-rules>
    <cloud-backup>
        <!--
        Back up the following user data to the cloud:
        - The entire Room database.
        - All SharedPreferences.
        - All files in internal storage, which includes user-captured images.
        -->
        <include domain="database" path="." />
        <include domain="sharedpref" path="." />
        <include domain="file" path="." />
    </cloud-backup>
    <device-transfer>
        <!--
        The same rules apply for device-to-device transfers.
        -->
        <include domain="database" path="." />
        <include domain="sharedpref" path="." />
        <include domain="file" path="." />
    </device-transfer>
</data-extraction-rules>