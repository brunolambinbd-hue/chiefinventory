<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        android:elevation="4dp"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar" />

    <Button
        android:id="@+id/btn_search"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        android:text="@string/search_button" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"> 

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Recherche Simple -->
            <EditText
                android:id="@+id/et_search_simple"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/simple_search_hint"
                android:inputType="text"
                tools:ignore="Autofill" />

            <!-- Bouton pour afficher/masquer la recherche avancée -->
            <TextView
                android:id="@+id/tv_toggle_advanced_search"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/advanced_search_show"
                android:textColor="?attr/colorPrimary"
                android:layout_gravity="end"
                android:padding="8dp" />

            <!-- Section Recherche Avancée (masquée par défaut) -->
            <LinearLayout
                android:id="@+id/advanced_search_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <EditText
                    android:id="@+id/et_search_titre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/item_title_hint"
                    android:inputType="textCapWords"
                    tools:ignore="Autofill" />

                <EditText
                    android:id="@+id/et_search_editor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/item_editor_hint"
                    android:inputType="textCapWords"
                    tools:ignore="Autofill" />

                <EditText
                    android:id="@+id/et_search_year"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/item_year_hint"
                    android:inputType="number"
                    tools:ignore="Autofill" />

                <EditText
                    android:id="@+id/et_searched_month"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/item_month_hint"
                    android:inputType="number"
                    tools:ignore="Autofill" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/super_category_search_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                    <AutoCompleteTextView
                        android:id="@+id/et_search_super_category"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/item_super_category_hint"
                        android:inputType="none"/>

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/category_search_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                    <AutoCompleteTextView
                        android:id="@+id/et_search_category"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/item_category_hint"
                        android:inputType="none"/>

                </com.google.android.material.textfield.TextInputLayout>

                <EditText
                    android:id="@+id/et_search_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/item_notes_hint"
                    android:inputType="textCapSentences"
                    tools:ignore="Autofill" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_search_results"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>